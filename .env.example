# Decidarr Configuration
# =====================

# Optional - Change the exposed port (default: 3100)
PORT=3100

# Optional - Set log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Required in production - high-entropy secret for wrapping JWT/encryption keys
# Generate with: openssl rand -hex 32
DECIDARR_SECRET=

# Recommended for public first-run setup - one-time gate before setupComplete
# Generate with: openssl rand -hex 16
DECIDARR_SETUP_SECRET=

# Allow private/LAN URLs for Plex, Tautulli, and Overseerr (self-hosted installs)
DECIDARR_ALLOW_PRIVATE_URLS=false

# Cookie security - defaults to true in production; set false for local HTTP dev
SECURE_COOKIES=false

# E2E test only - required header secret for POST /api/test/reset
E2E_TEST_RESET_SECRET=

# Note: Plex token, TMDB API key, Tautulli settings, and sync settings are all
# configured through the Settings UI in the application.
